---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/ui/Card.astro';
import Wrapper from '../../components/ui/Wrapper.astro';
import Accordion from '../../components/ui/Accordion.astro';
import FormAsesor from '../../components/forms/FormAsesor.astro';
import { cursos, categorias } from '../../data/cursos';
import { Clock, MonitorPlay, FileText } from 'lucide-astro';
import MediaImage from '../../components/ui/MediaImage.astro';
import { ROUTES, slugify } from '../../config/routes';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect(ROUTES.CURSOS);
}

// Search for a course with this slug
const course = cursos.find(c => c.slug === slug);

// If it's a category slug, redirect to index with filter
const isCategorySlug = categorias.some(cat => cat !== 'Todos' && slugify(cat) === slug);
if (isCategorySlug) {
  return Astro.redirect(`${ROUTES.CURSOS}?category=${slug}`);
}

if (!course) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={`${course.nombre} | IMB Institute`} description={course.descripcion}>
  
  <Wrapper class="relative overflow-x-clip" padded={false}>
    <div class="grid lg:grid-cols-3 gap-12 lg:gap-16 items-start relative">
      
      <!-- FIRST COLUMN: Main content flow -->
      <div class="lg:col-span-2">
        
        <!-- SECTION 1: Course Header Info -->
        <div class="relative py-12 lg:py-20">
          <!-- Full-width breakout background (White) -->
          <div class="absolute inset-y-0 left-[-100vw] right-[-100vw] bg-surface-0 z-0 shadow-sm border-b border-border-subtle/30"></div>
          
          <div class="relative z-10">
            <h1 class="font-display text-4xl lg:text-5xl font-extrabold text-text-primary leading-tight mb-6 tracking-tight">{course.nombre}</h1>
            <p class="font-sans text-xl text-text-secondary leading-relaxed mb-10">{course.descripcion}</p>
            
            <div class="flex flex-wrap items-center gap-8 lg:gap-12">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-imb/5 flex items-center justify-center">
                  <Clock size={20} class="text-imb" />
                </div>
                <div>
                  <p class="font-sans text-[10px] font-bold uppercase tracking-widest text-text-secondary">Duración</p>
                  <h4 class="font-display text-base font-bold text-text-primary">{course.duracion}</h4>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-imb/5 flex items-center justify-center">
                  <MonitorPlay size={20} class="text-imb" />
                </div>
                <div>
                  <p class="font-sans text-[10px] font-bold uppercase tracking-widest text-text-secondary">Modalidad</p>
                  <h4 class="font-display text-base font-bold text-text-primary">{course.modalidad}</h4>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-imb/5 flex items-center justify-center">
                  <FileText size={20} class="text-imb" />
                </div>
                <div>
                  <p class="font-sans text-[10px] font-bold uppercase tracking-widest text-text-secondary">Certificación</p>
                  <h4 class="font-display text-base font-bold text-text-primary">{course.certificacion}</h4>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- SECTION 2: Course Details & Curriculum -->
        <div class="relative py-16 lg:py-24 space-y-20">
          <!-- Full-width breakout background (Surface 50) -->
          <div class="absolute inset-y-0 left-[100vw] -right-[100vw] bg-surface-50 z-0"></div>
          
          <div class="relative z-10 space-y-20">
            <!-- About Section -->
            <section>
              <h2 class="font-display text-3xl lg:text-4xl font-bold text-text-primary mb-6 tracking-tight">Acerca del programa</h2>
              <div class="prose prose-lg text-text-secondary max-w-none leading-relaxed space-y-6">
                <p>{course.descripcion}</p>
                <p>Este programa ha sido diseñado cuidadosamente por expertos de la industria para proporcionarte las habilidades prácticas y teóricas necesarias para destacar en tu campo profesional, utilizando metodologías actualizadas y casos de estudio reales.</p>
              </div>
            </section>

            <!-- Curriculum Section -->
            <section>
              <div class="mb-10">
                <h2 class="font-display text-3xl lg:text-4xl font-bold text-text-primary mb-2 tracking-tight">Plan de Estudios</h2>
                <p class="font-sans text-text-secondary">Explora los módulos y temas que desarrollaremos a lo largo del programa.</p>
              </div>
              <div class="space-y-4">
                {course.modulos.map((modulo, i) => (
                  <Accordion title={modulo.titulo} isOpen={i === 0}>
                    <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3 py-2">
                      {modulo.items.map(item => (
                        <li class="flex items-start gap-2 text-text-secondary font-sans text-sm">
                          <div class="mt-1.5 w-1.5 h-1.5 rounded-full bg-imb shrink-0"></div>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </Accordion>
                ))}
              </div>
            </section>
          </div>
        </div>

      </div>

      <!-- SECOND COLUMN: Sticky Sidebar Form -->
      <aside class="lg:col-span-1 h-full py-12 lg:py-16">
        <div class="sticky top-28 z-20">
          <Card class="rounded-3xl p-8 lg:p-10 shadow-premium border border-border-subtle/20 bg-surface-0">
            <div class="mb-8">
              <h3 class="font-display text-2xl font-bold text-text-primary mb-2 tracking-tight">Contactar a un Asesor</h3>
              <p class="font-sans text-sm text-text-secondary leading-relaxed">Déjanos tus datos para enviarte el brochure detallado y el cronograma del programa.</p>
            </div>
            <FormAsesor cursoNombre={course.nombre} />
          </Card>
        </div>
      </aside>
    </div>
  </Wrapper>

</BaseLayout>
