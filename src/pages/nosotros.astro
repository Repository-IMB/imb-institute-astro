---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/ui/Card.astro';
import Wrapper from '../components/ui/Wrapper.astro';
import MediaImage from '../components/ui/MediaImage.astro';
import FormContacto from '../components/forms/FormContacto.astro';
import { Award, RefreshCw, HeartHandshake, Users2 } from 'lucide-astro';

export const prerender = true;

const valores = [
  { icon: Award, title: "Excelencia", desc: "Buscamos los más altos estándares en nuestra enseñanza y procesos metodológicos diarios." },
  { icon: RefreshCw, title: "Adaptabilidad", desc: "Evolucionamos ágilmente al ritmo de las nuevas demandas tecnológicas del mercado actual." },
  { icon: HeartHandshake, title: "Compromiso", desc: "Nos involucramos profundamente en el éxito y el crecimiento integral de nuestros alumnos." },
  { icon: Users2, title: "Empatía", desc: "Entendemos a fondo las necesidades únicas de cada estudiante y organización corporativa." }
];
---

<BaseLayout title="Nosotros | IMB Institute" description="Conoce nuestra historia, misión, visión y valores. Transformamos conocimiento en crecimiento.">

  <!-- Hero Dark -->
  <Wrapper class="relative bg-gray-950 overflow-hidden" full>
    <div class="absolute inset-0 z-0">
      <MediaImage src="https://images.unsplash.com/photo-1515162816999-a0c47dc192f7?auto=format&fit=crop&q=80&w=2000" alt="IMB Institute Equipo" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-gradient-to-b from-gray-900/95 via-gray-900/85 to-gray-900/95"></div>
    </div>
    <div class="max-w-[1100px] mx-auto text-center relative z-10">
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.15] mb-6 tracking-tight">
        Transformamos <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-red-600">Conocimiento</span> en Crecimiento.
      </h1>
      <p class="font-sans text-lg md:text-xl text-gray-300 mb-10 leading-relaxed max-w-3xl mx-auto">
        Creemos en el aprendizaje como el motor que impulsa a profesionales y organizaciones hacia la excelencia. Descubre cómo nuestra pasión por la innovación puede potenciar tu futuro.
      </p>
    </div>
  </Wrapper>

  <!-- Stats Grandes -->
  <Wrapper class="py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-imb rounded-3xl p-10 lg:p-16 flex flex-col justify-center text-white shadow-premium">
        <div class="font-display text-7xl lg:text-8xl font-bold tracking-tighter mb-4">95%</div>
        <p class="font-sans text-lg lg:text-xl font-medium text-red-100 max-w-sm leading-relaxed">Tasa de empleabilidad y mejora laboral en nuestros egresados</p>
      </div>
      <div class="bg-gray-900 border border-white/5 rounded-3xl p-10 lg:p-16 flex flex-col justify-center text-white shadow-premium">
        <div class="font-display text-7xl lg:text-8xl font-bold tracking-tighter mb-4">+10k</div>
        <p class="font-sans text-lg lg:text-xl font-medium text-gray-400 max-w-sm leading-relaxed">Alumnos y ejecutivos capacitados en toda Latinoamérica</p>
      </div>
    </div>
  </Wrapper>

  <!-- Quiénes Somos -->
  <Wrapper class="mb-24" padded={false}>
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-start border-t border-border-subtle pt-16">
      <div class="lg:col-span-5">
        <h2 class="font-display text-3xl lg:text-5xl font-bold text-text-primary tracking-tight leading-tight">
          Potenciando el talento en un mundo en evolución
        </h2>
      </div>
      <div class="lg:col-span-7 pt-2">
        <p class="font-sans text-lg lg:text-xl text-text-secondary leading-relaxed mb-8">
          Somos una institución líder en formación profesional y empresarial, dedicada a potenciar el talento y la competitividad. Nuestra metodología combina innovación, tecnología y asesoría especializada para brindar programas de alto impacto que transforman el aprendizaje en resultados reales.
        </p>
        <div class="grid sm:grid-cols-2 gap-10 mt-12 pt-12 border-t border-border-subtle">
          <div>
            <h4 class="text-sm font-bold uppercase tracking-wide text-text-primary mb-3">Nuestra Misión</h4>
            <p class="text-text-secondary leading-relaxed">
              Brindar formación de alta calidad a profesionales que buscan potenciar sus talentos y optimizar procesos corporativos.
            </p>
          </div>
          <div>
            <h4 class="font-sans text-sm font-bold uppercase tracking-wide text-text-primary mb-3">Nuestra Visión</h4>
            <p class="text-text-secondary leading-relaxed">
              Ser la organización líder en América Latina en capacitación especializada en calidad, mantenimiento profesional y gestión empresarial.
            </p>
          </div>
        </div>
      </div>
    </div>
  </Wrapper>

  <!-- Valores -->
  <Wrapper class="bg-surface-0 border-t border-border-subtle">
    <div class="text-center mb-16 max-w-2xl mx-auto">
      <h2 class="font-display text-3xl lg:text-4xl font-bold text-text-primary mb-4 tracking-tight">Nuestros valores fundamentales</h2>
      <p class="font-sans text-lg text-text-secondary">Los principios inquebrantables que sostienen nuestra excelencia académica y garantizan el éxito de nuestra comunidad.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
      {valores.map((v) => (
        <Card class="p-6 group hover:shadow-premium">
          <div class="w-10 h-10 bg-surface-50 rounded-xl flex items-center justify-center text-imb mb-4 shadow-sm">
            <v.icon size={20} />
          </div>
          <h3 class="font-display text-lg font-bold text-text-primary mb-2 leading-snug">{v.title}</h3>
          <p class="text-text-secondary leading-relaxed">{v.desc}</p>
        </Card>
      ))}
    </div>
  </Wrapper>

  <!-- Formulario Contacto -->
  <Wrapper class="bg-surface-50 border-t border-border-subtle">
    <div class="max-w-3xl mx-auto">
      <Card class="rounded-3xl p-8 lg:p-12 shadow-premium">
        <div class="text-center mb-10">
          <h3 class="font-display text-3xl font-bold text-text-primary mb-4 tracking-tight">Descubre cómo IMB puede transformar tu futuro</h3>
          <p class="font-sans text-lg text-text-secondary">Completa tus datos y un asesor académico se comunicará contigo de inmediato.</p>
        </div>
        <FormContacto />
      </Card>
    </div>
  </Wrapper>

</BaseLayout>
