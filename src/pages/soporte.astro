---
import BaseLayout from '../layouts/BaseLayout.astro';
import Accordion from '../components/ui/Accordion.astro';
import Card from '../components/ui/Card.astro';
import Wrapper from '../components/ui/Wrapper.astro';
import FormSoporte from '../components/forms/FormSoporte.astro';

export const prerender = true;

const faqs = [
  {
    pregunta: "¿Cómo ingreso a las sesiones en vivo?",
    respuesta: "Recibirás un correo electrónico 24 horas antes del inicio con el enlace directo de Zoom o Google Meet. También puedes encontrar el enlace en la pestaña \"Sesiones\" dentro de tu Aula Virtual."
  },
  {
    pregunta: "¿Cómo ingreso a la plataforma virtual?",
    respuesta: "Al matricularte, te enviaremos tus credenciales de acceso al correo registrado. Ve a la opción \"Iniciar Sesión\" en nuestra web e ingresa tu usuario y contraseña."
  },
  {
    pregunta: "¿Las sesiones en vivo se graban? ¿Cómo puedo verlas?",
    respuesta: "Sí, todas las sesiones quedan grabadas y se suben a la plataforma dentro de las siguientes 24 horas para que puedas repasarlas a tu ritmo."
  },
  {
    pregunta: "¿No veo mi curso en el aula virtual?",
    respuesta: "En el aula virtual, los módulos del curso se van agregando progresivamente conforme se desarrollan las sesiones. Al finalizar el primer módulo y pasar la semana de pausa, se activará el segundo módulo de forma automática."
  }
];
---

<BaseLayout title="Soporte Académico | IMB Institute" description="¿Necesitas ayuda con tu curso? Estamos aquí para acompañarte. Respuesta en 24-48 horas hábiles.">

  <!-- Header Oscuro -->
  <Wrapper as="div" class="bg-gray-950 text-white text-center mb-16" full class:list={["py-20 lg:py-24"]}>
    <h1 class="font-display text-4xl lg:text-5xl font-extrabold mb-6 tracking-tight">¿Necesitas ayuda con tu curso?</h1>
    <p class="font-sans text-lg text-gray-300 max-w-2xl mx-auto leading-relaxed">
      Estamos aquí para acompañarte en tu formación. Cuéntanos qué sucede y te responderemos a la brevedad (en un máximo de 24 a 48 horas hábiles).
    </p>
  </Wrapper>

  <!-- Main Content -->
  <Wrapper class="pb-24" padded={false}>
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- FAQ Section -->
      <div>
        <h2 class="font-display text-3xl font-bold text-text-primary mb-8 tracking-tight">Preguntas Frecuentes</h2>
        <div class="space-y-4">
          {faqs.map((faq, i) => (
            <Accordion title={faq.pregunta} isOpen={i === 0}>
              <p>{faq.respuesta}</p>
            </Accordion>
          ))}
        </div>
      </div>

      <!-- Support Form -->
      <Card class="rounded-3xl p-8 lg:p-12 shadow-premium">
        <h3 class="font-display text-2xl font-bold text-text-primary mb-2">Registra tu consulta</h3>
        <p class="font-sans text-sm text-text-secondary mb-10">Si no encontraste lo que buscabas, déjanos tus datos y te ayudaremos.</p>
        <FormSoporte />
      </Card>
    </div>
  </Wrapper>

</BaseLayout>
