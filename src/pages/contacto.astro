---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/ui/Card.astro';
import Wrapper from '../components/ui/Wrapper.astro';
import FormAlianzas from '../components/forms/FormAlianzas.astro';
import { Users2, Building2 } from 'lucide-astro';

export const prerender = true;
---

<BaseLayout title="Contacto y Alianzas | IMB Institute" description="¿Representas a una empresa? Desarrollamos programas a medida y alianzas estratégicas B2B.">
  <Wrapper class="pt-12 lg:pt-20 pb-24" padded={false}>
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left Column -->
      <div>
        <h1 class="font-display text-4xl lg:text-5xl font-extrabold mb-6 tracking-tight">Contáctanos y Forma Alianzas.</h1>
        <p class="font-sans text-lg lg:text-xl text-text-secondary leading-relaxed mb-8">
          ¿Representas a una empresa o institución? En IMB Institute desarrollamos programas a medida y alianzas estratégicas para potenciar el talento de los equipos de trabajo a nivel corporativo.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
          <Card class="p-6">
            <div class="w-10 h-10 bg-surface-50 rounded-xl flex items-center justify-center text-imb mb-4">
              <Users2 size={20} />
            </div>
            <h4 class="font-display text-lg font-bold">Programas a medida</h4>
            <p class="font-sans text-xs text-text-secondary mt-1">Capacitación 100% enfocada en tus KPIs.</p>        
          </Card>
          <Card class="p-6">
            <div class="w-10 h-10 bg-surface-50 rounded-xl flex items-center justify-center text-imb mb-4">
              <Building2 size={20} />
            </div>
            <h4 class="font-display text-lg font-bold">Alianzas Institucionales</h4>
            <p class="font-sans text-xs text-text-secondary mt-1">Convenios de valor para tu organización.</p>       
          </Card>
        </div>
      </div>

      <!-- Right Column: Form -->
      <Card class="rounded-3xl p-8 lg:p-12 shadow-premium">
        <h3 class="font-display text-2xl font-bold mb-2">Inicia una Alianza</h3>
        <p class="font-sans text-sm text-text-secondary mb-10">Un asesor corporativo diseñará un plan adaptado a tu empresa.</p>
        <FormAlianzas />
      </Card>

    </div>
  </Wrapper>
</BaseLayout>
