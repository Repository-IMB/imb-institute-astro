---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSubmissionsCount, getSubmissionsCountByType, getRecentSubmissions } from '../../lib/db';
import type { FormType } from '../../types/submission';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import { 
  Inbox, FileText, Scale, Briefcase, GraduationCap, 
  UserCheck, AlertCircle, User
} from 'lucide-astro';

export const prerender = false;

const db = env.DB;

let totalCount = 0;
let countsByType: { form_type: string; count: number }[] = [];
let recentSubmissions: Awaited<ReturnType<typeof getRecentSubmissions>> = [];
let error: string | null = null;

if (!db) {
  error = 'Base de datos no disponible. Asegúrate de configurar el D1 binding.';
} else {
  try {
    totalCount = await getSubmissionsCount(db);
    countsByType = await getSubmissionsCountByType(db);
    recentSubmissions = await getRecentSubmissions(db, 7);
  } catch (e) {
    error = e instanceof Error ? e.message : 'Error al cargar los datos';
  }
}

const formTypeLabels: Record<FormType, string> = {
  contacto: 'Contacto',
  soporte: 'Soporte',
  reclamaciones: 'Reclamaciones',
  alianzas: 'Alianzas',
  asesor: 'Asesor',
  matricula: 'Matrícula',
};

const formTypeIcons: Record<FormType, any> = {
  contacto: User,
  soporte: AlertCircle,
  reclamaciones: Scale,
  alianzas: Briefcase,
  asesor: UserCheck,
  matricula: GraduationCap,
};

const formTypeColors: Record<FormType, { icon: string }> = {
  contacto: { icon: 'text-blue-600 bg-blue-50/80 border border-blue-100' },
  soporte: { icon: 'text-emerald-600 bg-emerald-50/80 border border-emerald-100' },
  reclamaciones: { icon: 'text-rose-600 bg-rose-50/80 border border-rose-100' },
  alianzas: { icon: 'text-purple-600 bg-purple-50/80 border border-purple-100' },
  asesor: { icon: 'text-amber-600 bg-amber-50/80 border border-amber-100' },
  matricula: { icon: 'text-red-700 bg-red-50/80 border border-red-100' },
};

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('es-ES', { 
    day: '2-digit', 
    month: 'short', 
    year: 'numeric', 
    hour: '2-digit', 
    minute: '2-digit' 
  });
}

function getClientPreview(data: Record<string, unknown>): string {
  const name = data.nombres || data.nombre || '';
  const surname = data.apellidos || '';
  const email = data.correo || data.email || '';
  
  const fullName = `${name} ${surname}`.trim();
  if (fullName && email) {
    return `${fullName} (${email})`;
  }
  return fullName || String(email) || 'Sin identificar';
}
---

<AdminLayout title="Dashboard | Admin IMB Institute">
  <div class="space-y-8 animate-fade-in opacity-0">
    <!-- Header -->
    <div class="flex items-center justify-between pb-6 border-b border-border-subtle">
      <div>
        <h1 class="font-display text-2xl font-bold text-text-primary tracking-tight">Dashboard</h1>
        <p class="text-text-secondary text-sm mt-1">Resumen del sistema y envíos de formularios</p>
      </div>
      <Button href="/admin/submissions" variant="outline">
        Ver todos los registros
      </Button>
    </div>

    <!-- Error State -->
    {error && (
      <div class="flex gap-4 p-5 bg-rose-50 border border-rose-100 rounded-xl text-rose-800 shadow-sm">
        <AlertCircle class="w-6 h-6 shrink-0 text-rose-600" />
        <div>
          <h4 class="font-display font-semibold text-sm mb-1">Configuración Requerida</h4>
          <p class="font-sans text-sm text-rose-700/90 leading-relaxed">{error}</p>
        </div>
      </div>
    )}

    <!-- Stats Grid with Icons -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Total submissions -->
      <Card 
        href="/admin/submissions" 
        class="p-6 border border-border-subtle hover:border-text-primary hover:shadow-sm duration-200 flex items-center justify-between"
      >
        <div>
          <span class="text-xs font-semibold text-text-secondary uppercase tracking-wider">Total Recibidos</span>
          <span class="block font-display text-3xl font-bold text-text-primary mt-2">{totalCount.toLocaleString('es-ES')}</span>
        </div>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center text-text-primary bg-surface-100 border border-border-subtle">
          <Inbox size={20} />
        </div>
      </Card>

      <!-- Submissions count cards per form type -->
      {Object.entries(formTypeLabels).map(([key, label]) => {
        const typeCount = countsByType.find(c => c.form_type === key)?.count ?? 0;
        const colorConfig = formTypeColors[key as FormType] || { icon: 'text-text-secondary bg-surface-50' };
        const IconComponent = formTypeIcons[key as FormType] || FileText;
        return (
          <Card 
            href={`/admin/submissions?type=${key}`}
            class={`p-6 border border-border-subtle hover:border-text-primary hover:shadow-sm duration-200 flex items-center justify-between ${typeCount === 0 ? 'opacity-50 border-dashed bg-surface-50/20' : ''}`}
          >
            <div>
              <span class="text-xs font-semibold text-text-secondary uppercase tracking-wider">{label}</span>
              <span class="block font-display text-3xl font-bold text-text-primary mt-2">{typeCount.toLocaleString('es-ES')}</span>
            </div>
            <div class={`w-10 h-10 rounded-xl flex items-center justify-center ${colorConfig.icon}`}>
              <IconComponent size={20} />
            </div>
          </Card>
        );
      })}
    </div>

    <!-- Recent Submissions Table (Full Width) -->
    <div class="space-y-4">
      <h2 class="font-display text-lg font-bold text-text-primary">Submissions Recientes (Últimos 7 días)</h2>
      
      <Card class="overflow-hidden p-0">
        {recentSubmissions.length === 0 ? (
          <div class="px-6 py-12 text-center">
            <div class="w-10 h-10 rounded-full bg-surface-50 flex items-center justify-center mx-auto text-text-secondary mb-3">
              <Inbox size={20} />
            </div>
            <p class="font-sans text-sm text-text-secondary font-medium">No hay registros en los últimos 7 días.</p>
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-border-subtle bg-surface-50/50">
                  <th class="px-6 py-4 text-left font-sans text-xs font-bold uppercase tracking-wider text-text-secondary">ID</th>
                  <th class="px-6 py-4 text-left font-sans text-xs font-bold uppercase tracking-wider text-text-secondary">Tipo</th>
                  <th class="px-6 py-4 text-left font-sans text-xs font-bold uppercase tracking-wider text-text-secondary">Fecha</th>
                  <th class="px-6 py-4 text-left font-sans text-xs font-bold uppercase tracking-wider text-text-secondary">Identificador</th>
                  <th class="px-6 py-4 text-right font-sans text-xs font-bold uppercase tracking-wider text-text-secondary">Acciones</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border-subtle font-sans text-sm">
                {recentSubmissions.map((sub) => (
                  <tr 
                    class="group hover:bg-surface-50/70 transition-colors duration-150 cursor-pointer"
                    onclick={`window.location.href='/admin/submissions/${sub.id}'`}
                  >
                    <td class="px-6 py-4 font-mono text-xs text-text-secondary">#{sub.id}</td>
                    <td class="px-6 py-4 whitespace-nowrap font-medium text-text-primary">
                      {formTypeLabels[sub.form_type as FormType] ?? sub.form_type}
                    </td>
                    <td class="px-6 py-4 text-text-secondary whitespace-nowrap">
                      {formatDate(sub.created_at)}
                    </td>
                    <td class="px-6 py-4 text-text-secondary truncate max-w-xs">
                      {getClientPreview(sub.data)}
                    </td>
                    <td class="px-6 py-4 text-right whitespace-nowrap">
                      <a 
                        href={`/admin/submissions/${sub.id}`}
                        class="text-xs font-bold text-imb hover:underline hover:text-imb-hover transition-colors"
                      >
                        Ver detalles
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </Card>
    </div>
  </div>
</AdminLayout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
