---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSubmissions, getSubmissionsCount } from '../../../lib/db';
import type { FormType } from '../../../types/submission';
import { ArrowLeft, Inbox } from 'lucide-astro';

export const prerender = false;

const db = env.DB;

// Query params
const url = Astro.url;
const formTypeFilter = url.searchParams.get('type') as FormType | null;
const dateRangeParam = url.searchParams.get('range') || '';
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10));
const perPage = 20;

// Parse date range: "YYYY-MM-DD to YYYY-MM-DD"
let startDate = '';
let endDate = '';
if (dateRangeParam.includes(' to ')) {
  [startDate, endDate] = dateRangeParam.split(' to ');
} else if (dateRangeParam) {
  startDate = dateRangeParam;
  endDate = dateRangeParam;
}

let submissions: Awaited<ReturnType<typeof getSubmissions>> = [];
let totalCount = 0;
let totalPages = 0;
let error: string | null = null;

const formTypeLabels: Record<FormType, string> = {
  contacto: 'Contacto',
  soporte: 'Soporte',
  reclamaciones: 'Reclamaciones',
  alianzas: 'Alianzas',
  asesor: 'Asesor',
  matricula: 'Matrícula',
};

if (!db) {
  error = 'Base de datos no disponible. Asegúrate de configurar el D1 binding.';
} else {
  try {
    totalCount = await getSubmissionsCount(db, formTypeFilter || undefined);
    totalPages = Math.ceil(totalCount / perPage);
    submissions = await getSubmissions(db, {
      form_type: formTypeFilter || undefined,
      startDate: startDate || undefined,
      endDate: endDate || undefined,
      limit: perPage,
      offset: (page - 1) * perPage,
    });
  } catch (e) {
    error = e instanceof Error ? e.message : 'Error al cargar los datos';
  }
}

const formTypeColors: Record<FormType, string> = {
  contacto: 'bg-blue-50 text-blue-700 border-blue-200/60',
  soporte: 'bg-emerald-50 text-emerald-700 border-emerald-200/60',
  reclamaciones: 'bg-rose-50 text-rose-700 border-rose-200/60',
  alianzas: 'bg-purple-50 text-purple-700 border-purple-200/60',
  asesor: 'bg-amber-50 text-amber-700 border-amber-200/60',
  matricula: 'bg-red-50 text-red-800 border-red-200/60',
};

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

function buildQueryString(params: Record<string, string | number>): string {
  const p = new URLSearchParams();
  for (const [k, v] of Object.entries(params)) {
    if (v !== '' && v !== undefined && v !== null) p.set(k, String(v));
  }
  const s = p.toString();
  return s ? '?' + s : '';
}

function getClientPreview(data: Record<string, unknown>): string {
  const name = data.nombres || data.nombre || '';
  const surname = data.apellidos || '';
  const email = data.correo || data.email || '';
  
  const fullName = `${name} ${surname}`.trim();
  if (fullName && email) {
    return `${fullName} (${email})`;
  }
  return fullName || String(email) || 'Sin identificar';
}

const pageTitle = formTypeFilter 
  ? `Registro de Formulario de ${formTypeLabels[formTypeFilter]}`
  : 'Registro de Todos los Formularios';
---

<AdminLayout title={`${pageTitle} | Admin IMB Institute`}>
  <!-- Flatpickr CSS & Script CDN -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

  <div class="space-y-6 animate-fade-in opacity-0">
    <!-- Header -->
    <div class="flex items-center justify-between flex-wrap gap-4 pb-6 border-b border-border-subtle">
      <div class="flex items-center gap-4">
        <a 
          href="/admin" 
          class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border-subtle bg-surface-0 hover:bg-surface-50 transition-colors text-text-secondary hover:text-text-primary"
        >
          <ArrowLeft size={16} />
        </a>
        <div>
          <h1 class="font-display text-2xl font-bold text-text-primary tracking-tight">{pageTitle}</h1>
          <p class="text-text-secondary text-sm mt-1">Registros recibidos en la plataforma</p>
        </div>
      </div>

      <button
        id="btn-export"
        class="inline-flex items-center gap-2 px-4 py-2 bg-imb text-white text-sm font-semibold rounded-lg hover:bg-imb-hover transition-colors shadow-sm"
        data-type={formTypeFilter || ''}
        data-start={startDate}
        data-end={endDate}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Exportar CSV
      </button>
    </div>

    {error && (
      <div class="bg-rose-50 border border-rose-100 text-rose-800 px-4 py-3 rounded-lg text-sm">
        <p class="font-semibold">Error:</p>
        <p class="mt-0.5">{error}</p>
      </div>
    )}

    <!-- Date Filter Form -->
    <form method="get" class="bg-surface-0 rounded-xl border border-border-subtle p-5 shadow-sm">
      {formTypeFilter && <input type="hidden" name="type" value={formTypeFilter} />}
      
      <div class="flex flex-col sm:flex-row gap-4 items-end">
        <div class="flex-1 min-w-[280px] w-full">
          <label class="block text-xs font-semibold text-text-secondary uppercase tracking-wider mb-2">Filtrar por Rango de Fechas</label>
          <input
            id="date-picker"
            type="text"
            name="range"
            value={dateRangeParam}
            placeholder="Selecciona un rango de fechas..."
            class="w-full px-4 py-2.5 bg-surface-50 border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-imb"
          />
        </div>
        
        <div class="flex gap-2 w-full sm:w-auto">
          <button
            type="submit"
            class="cursor-pointer flex-1 sm:flex-initial px-6 py-2.5 bg-text-primary text-white text-sm font-semibold rounded-lg hover:bg-gray-800 transition-colors"
          >
            Filtrar
          </button>
          <a
            href={formTypeFilter ? `/admin/submissions?type=${formTypeFilter}` : '/admin/submissions'}
            class="flex-1 sm:flex-initial px-6 py-2.5 bg-surface-50 border border-border-subtle text-text-secondary text-sm font-semibold rounded-lg hover:bg-surface-100 transition-colors text-center"
          >
            Limpiar
          </a>
        </div>
      </div>
    </form>

    <!-- Table -->
    <div class="bg-surface-0 rounded-xl border border-border-subtle shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-border-subtle flex items-center justify-between">
        <span class="text-sm text-text-secondary">
          Mostrando <strong>{submissions.length}</strong> de <strong>{totalCount}</strong> submissions
          {page > 1 && `(página ${page} de ${totalPages})`}
        </span>
      </div>

      {submissions.length === 0 ? (
        <div class="px-6 py-16 text-center">
          <div class="w-10 h-10 rounded-full bg-surface-50 flex items-center justify-center mx-auto text-text-secondary mb-3">
            <Inbox size={20} />
          </div>
          <p class="text-text-secondary text-sm font-medium">No hay registros con los filtros seleccionados</p>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-surface-50/50 border-b border-border-subtle">
                <th class="px-6 py-4 text-left font-sans text-xs font-bold uppercase tracking-wider text-text-secondary whitespace-nowrap">ID</th>
                {!formTypeFilter && (
                  <th class="px-6 py-4 text-left font-sans text-xs font-bold uppercase tracking-wider text-text-secondary whitespace-nowrap">Tipo</th>
                )}
                <th class="px-6 py-4 text-left font-sans text-xs font-bold uppercase tracking-wider text-text-secondary whitespace-nowrap">Fecha</th>
                <th class="px-6 py-4 text-left font-sans text-xs font-bold uppercase tracking-wider text-text-secondary">Identificador</th>
                <th class="px-6 py-4 text-right font-sans text-xs font-bold uppercase tracking-wider text-text-secondary">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border-subtle font-sans text-sm">
              {submissions.map((sub) => (
                <tr 
                  class="group hover:bg-surface-50/70 transition-colors duration-150 cursor-pointer"
                  onclick={`window.location.href='/admin/submissions/${sub.id}'`}
                >
                  <td class="px-6 py-4 font-mono text-xs text-text-secondary whitespace-nowrap">#{sub.id}</td>
                  {!formTypeFilter && (
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class={`inline-flex px-2.5 py-0.5 rounded-full text-xs font-semibold border ${formTypeColors[sub.form_type as FormType] ?? 'bg-gray-100 text-gray-700'}`}>
                        {formTypeLabels[sub.form_type as FormType] ?? sub.form_type}
                      </span>
                    </td>
                  )}
                  <td class="px-6 py-4 text-text-secondary whitespace-nowrap">{formatDate(sub.created_at)}</td>
                  <td class="px-6 py-4 text-text-secondary truncate max-w-xs">
                    {getClientPreview(sub.data)}
                  </td>
                  <td class="px-6 py-4 text-right whitespace-nowrap">
                    <a 
                      href={`/admin/submissions/${sub.id}`}
                      class="text-xs font-bold text-imb hover:underline hover:text-imb-hover transition-colors"
                    >
                      Ver detalles
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <!-- Pagination -->
      {totalPages > 1 && (
        <div class="px-6 py-4 border-t border-border-subtle flex items-center justify-between font-sans">
          <a
            href={page > 1 ? `/admin/submissions${buildQueryString({ type: formTypeFilter || '', range: dateRangeParam, page: page - 1 })}` : '#'}
            class={`inline-flex items-center px-3 py-2 text-sm font-semibold rounded-lg transition-colors ${page > 1 ? 'text-text-primary hover:bg-surface-50' : 'text-text-secondary cursor-not-allowed'}`}
            aria-disabled={page <= 1}
          >
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Anterior
          </a>
          <span class="text-sm text-text-secondary">
            Página {page} de {totalPages}
          </span>
          <a
            href={page < totalPages ? `/admin/submissions${buildQueryString({ type: formTypeFilter || '', range: dateRangeParam, page: page + 1 })}` : '#'}
            class={`inline-flex items-center px-3 py-2 text-sm font-semibold rounded-lg transition-colors ${page < totalPages ? 'text-text-primary hover:bg-surface-50' : 'text-text-secondary cursor-not-allowed'}`}
            aria-disabled={page >= totalPages}
          >
            Siguiente
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script is:inline>
  // Initialize date range picker
  document.addEventListener('DOMContentLoaded', () => {
    flatpickr("#date-picker", {
      mode: "range",
      dateFormat: "Y-m-d",
      locale: {
        rangeSeparator: " to ",
        firstDayOfWeek: 1,
        weekdays: {
          shorthand: ["Do", "Lu", "Ma", "Mi", "Ju", "Vi", "Sa"],
          longhand: ["Domingo", "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado"]
        },
        months: {
          shorthand: ["Ene", "Feb", "Mar", "Abr", "May", "Jun", "Jul", "Ago", "Sep", "Oct", "Nov", "Dic"],
          longhand: ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"]
        }
      }
    });
  });
</script>

<script>
  import { actions } from 'astro:actions';

  const btn = document.getElementById('btn-export');
  if (btn) {
    btn.addEventListener('click', async () => {
      const type = btn.dataset.type || undefined;
      const start = btn.dataset.start || undefined;
      const end = btn.dataset.end || undefined;

      btn.setAttribute('disabled', 'true');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="inline-flex items-center gap-2"><svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Generando...</span>';

      try {
        const { data, error } = await actions.exportCSV({
          form_type: type,
          startDate: start,
          endDate: end,
        });

        if (error) {
          alert('Error al exportar: ' + error.message);
          return;
        }

        if (data) {
          const blob = new Blob([data.csv], { type: 'text/csv;charset=utf-8;' });
          const link = document.createElement('a');
          link.href = URL.createObjectURL(blob);
          link.download = data.filename;
          link.click();
          URL.revokeObjectURL(link.href);
        }
      } catch (e) {
        alert('Error al exportar: ' + (e instanceof Error ? e.message : 'Error desconocido'));
      } finally {
        btn.removeAttribute('disabled');
        btn.innerHTML = originalText;
      }
    });
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
