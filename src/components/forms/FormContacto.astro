---
import InputField from '../ui/InputField.astro';
import Button from '../ui/Button.astro';
import PhoneInput from '../ui/PhoneInput.astro';

export interface Props {
  cursoNombre?: string;
  class?: string;
}

const { cursoNombre, class: className } = Astro.props;

const actionUrl = cursoNombre
  ? `/actions/asesor?cursoNombre=${encodeURIComponent(cursoNombre)}`
  : '/actions/contacto';
---

<form
  method="POST"
  action={actionUrl}
  class:list={["space-y-8", className]}
>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <InputField label="Nombres" name="nombres" placeholder="Carlos" />
    <InputField label="Apellidos" name="apellidos" placeholder="Mendoza" />
  </div>

  <PhoneInput label="WhatsApp" name="telefono" id="contacto-telefono" />

  <InputField label="Correo Electrónico" name="correo" type="email" placeholder="correo@ejemplo.com" />

  {!cursoNombre && (
    <InputField label="Consulta" name="consulta" type="textarea" rows={4} placeholder="¿En qué programa estás interesado o cómo podemos ayudarte?" />
  )}

  <div class="pt-4">
    <Button
      type="submit"
      class="w-full py-4"
    >
      {cursoNombre ? 'Solicitar Información' : 'Enviar Mensaje'}
    </Button>
  </div>
</form>
