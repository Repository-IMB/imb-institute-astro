---
interface Props {
  label: string;
  name: string;
  options: Array<string | { value: string; label: string }>;
  required?: boolean;
  class?: string;
}

const {
  label,
  name,
  options,
  required = true,
  class: className,
} = Astro.props;

const selectClasses = "w-full px-0 py-2 bg-transparent border-0 border-b-2 border-border-subtle focus:ring-0 focus:border-imb focus:outline-none transition-all font-display text-base text-text-primary cursor-pointer appearance-none pr-8";
---

<div class:list={["relative group", className]}>
  <label class="block font-sans text-sm font-medium text-text-secondary mb-1 transition-colors group-focus-within:text-imb">
    {label} {required && <span class="text-imb">*</span>}
  </label>
  <select name={name} required={required} class={selectClasses}>
    {options.map((opt) => {
      const val = typeof opt === 'string' ? opt : opt.value;
      const text = typeof opt === 'string' ? opt : opt.label;
      const isPlaceholder = val === '';
      return <option value={val} disabled={isPlaceholder} selected={isPlaceholder} class="bg-surface-0 text-text-primary">{text}</option>;
    })}
  </select>
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-0 bottom-3 w-5 h-5 text-icon-muted pointer-events-none">
    <path d="m6 9 6 6 6-6"/>
  </svg>
</div>
