---
interface Props {
  title: string;
  isOpen?: boolean;
  class?: string;
}

const { title, isOpen = false, class: className } = Astro.props;
---

<details class:list={["rounded-xl border border-border-subtle shadow-sm overflow-hidden transition-all", className]} open={isOpen}>
  <summary class="w-full px-6 py-4 flex items-center justify-between bg-surface-0 hover:bg-surface-100 transition-colors cursor-pointer list-none">
    <h3 class="font-display font-bold text-lg md:text-xl text-text-primary text-left pr-4">{title}</h3>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary shrink-0 transition-transform duration-200 accordion-chevron">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  </summary>
  <div class="px-6 py-5 bg-surface-50 border-t border-border-muted font-sans text-base text-text-secondary">
    <slot />
  </div>
</details>

<style>
  details[open] .accordion-chevron {
    transform: rotate(180deg);
  }
  summary::-webkit-details-marker {
    display: none;
  }
</style>
