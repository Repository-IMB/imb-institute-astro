---
interface Props {
  href?: string;
  class?: string;
  [key: string]: any;
}

const { href, class: className, ...rest } = Astro.props;

const cardClasses = "bg-surface-0 rounded-2xl border border-border-subtle shadow-sm hover:shadow-premium transition-all duration-300";
---

{href ? (
  <a href={href} class:list={[cardClasses, "block", className]} {...rest}>
    <slot />
  </a>
) : (
  <div class:list={[cardClasses, className]} {...rest}>
    <slot />
  </div>
)}
