---
import Wrapper from './Wrapper.astro';
import MediaImage from './MediaImage.astro';

interface Props {
  image: string;
  imageAlt?: string;
  badge?: string;
  class?: string;
}

const { image, imageAlt = "Hero Image", badge, class: className } = Astro.props;
---

<section class:list={["relative min-h-screen flex items-end overflow-hidden bg-surface-50", className]}>
  <!-- Background Layer — Positioned asymmetrically -->
  <div class="absolute inset-0 lg:left-1/3 z-0 pointer-events-none">
    <MediaImage 
      src={image} 
      alt={imageAlt} 
      class="w-full h-full object-cover grayscale opacity-40 mix-blend-multiply"
      loading="eager"
    />
    <!-- Stark Swiss Overlay -->
    <div class="absolute inset-0 bg-linear-to-t from-surface-50 via-transparent to-transparent"></div>
  </div>

  <!-- Content Layer — Aligned to 12-column Swiss Grid -->
  <Wrapper as="div" padded={false} class="relative z-10 w-full pb-24 lg:pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <div class="lg:col-span-8 space-y-12">
        {badge && (
          <span class="inline-block px-3 py-1 bg-imb text-white text-[10px] font-extrabold uppercase tracking-[0.3em]">
            {badge}
          </span>
        )}
        <div class="space-y-8">
          <slot />
        </div>
      </div>
    </div>
  </Wrapper>
</section>

<style>
  :global(h1) {
    margin-bottom: 0 !important;
  }
</style>
